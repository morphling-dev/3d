{
    "name": "morphling-dev/3d",
    "description": "Morphling Coding 3D (Domain Driven Design) Scaffolding Generator",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0-dev",
    "authors": [
        {
            "name": "Indra Ranuh",
            "email": "indraranuh1@gmail.com",
            "role": "Software Architect"
        }
    ],
    "require": {
        "php": "^8.2",
        "composer-runtime-api": "^2.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Morphling\\ThreeD\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Morphling\\ThreeD\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php ./vendor/bin/testbench package:discover --ansi"
        ],
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "lint": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Morphling\\ThreeD\\ThreeDServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}