---
import "../styles/global.css";
const { title = "Morphling 3D — Enterprise Architecture" } = Astro.props;
---

<!doctype html>
<html lang="en" x-data x-init="$store.sidebarOpen = false" x-cloak>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.min.css"
    />

    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" is:inline
    ></script>
  </head>

  <body
    class="antialiased selection:bg-emerald-500/30 bg-[#050505] text-neutral-400"
  >
    <div
      class="fixed top-0 z-[100] h-[1px] w-full bg-gradient-to-r from-transparent via-emerald-500/50 to-transparent"
    >
    </div>

    <header
      class="fixed top-0 z-50 w-full border-b border-neutral-900 bg-[#050505]/80 backdrop-blur-xl"
    >
      <div
        class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 py-5"
      >
        <div class="flex items-center gap-3">
          <img
            src="/assets/logo.png"
            alt="Logo"
            class="h-6 w-6 object-contain"
          />
          <span
            class="text-[11px] font-bold uppercase tracking-[0.4em] text-white"
            >Morphling 3D</span
          >
        </div>
        <div
          class="hidden md:flex items-center gap-6 text-[10px] font-bold uppercase tracking-widest text-neutral-500"
        >
          <a
            href="https://github.com/morphling-dev/3d"
            class="hover:text-white transition">GitHub</a
          >
          <span
            class="rounded-full border border-emerald-500/20 px-3 py-1 text-emerald-500 bg-emerald-500/5"
            >v1.0.0-dev</span
          >
        </div>
        <button
          @click="$store.sidebarOpen = true"
          class="md:hidden text-neutral-400 hover:text-emerald-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-7 w-7"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </header>

    <div class="mx-auto flex max-w-7xl px-4 sm:px-6 pt-28 sm:pt-32">
      <aside
        class="hidden lg:block fixed h-[calc(100vh-120px)] w-64 overflow-y-auto pr-8 custom-scrollbar"
      >
        <nav id="sidebar-nav" class="flex flex-col gap-4"></nav>
      </aside>

      <slot name="mobile-sidebar" />

      <main class="w-full lg:ml-72 pb-32">
        <slot />
      </main>
    </div>

    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"
      is:inline></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-markup-templating.min.js"
      is:inline></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-php.min.js"
      is:inline></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-bash.min.js"
      is:inline></script>
    <script type="module" src="/assets/app.js" is:inline></script>
  </body>
</html>
