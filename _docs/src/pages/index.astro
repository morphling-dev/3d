---
import DocLayout from "../layouts/DocLayout.astro";
---

<DocLayout>
  <div
    slot="mobile-sidebar"
    x-show="$store.sidebarOpen"
    class="fixed inset-0 z-[160] flex lg:hidden"
    style="display: none;"
  >
    <div class="fixed inset-0 bg-black/60" @click="$store.sidebarOpen = false">
    </div>
    <div class="relative h-full w-72 bg-[#111] border-r border-neutral-800 p-7">
      <nav id="sidebar-nav-mobile" class="flex flex-col gap-4"></nav>
    </div>
  </div>

  <article id="content" class="prose prose-invert prose-emerald max-w-3xl">
    <div class="flex items-center gap-2 text-emerald-500 mb-8">
      <span class="h-1 w-1 rounded-full bg-emerald-500 animate-pulse"></span>
      <span class="text-[10px] font-bold uppercase tracking-widest"
        >Loading Documentation...</span
      >
    </div>
  </article>
</DocLayout>
