                    @php
                        $relativeFilePath = 'modules/Transaction/Delivery/Views/index.blade.php';
                        $absolutePath = base_path($relativeFilePath);
                        $line = 1;
                        // Read version from composer.json
                        try {
                            $composer = json_decode(file_get_contents(base_path('composer.json')), true);
                            $version = $composer['version'] ?? 'v1.0.0';
                        } catch (\Throwable $e) {
                            $version = 'v1.0.0';
                        }
                    @endphp
                    <script>
                        function openCodeEditor() {
                            const file = @json($absolutePath);
                            const line = @json($line);
                            // Priority order: Cursor -> VS Code -> PHPStorm
                            const protocols = [
                                `cursor://file/${file}:${line}`,
                                `vscode://file/${file}:${line}`,
                                `phpstorm://open?file=${file}&line=${line}`
                            ];
                            let index = 0;
                            let hasOpened = false;
                            // Recursive function to try each protocol in order
                            function tryNext() {
                                if (index >= protocols.length || hasOpened) return;
                                console.log(`Attempting to open: ${protocols[index]}`);
                                window.location.href = protocols[index];
                                // If the browser loses focus, assume the editor was successfully opened
                                const onBlur = () => {
                                    hasOpened = true;
                                    window.removeEventListener('blur', onBlur);
                                };
                                window.addEventListener('blur', onBlur);
                                // Wait 500ms, if still on the same page, try the next protocol
                                setTimeout(() => {
                                    window.removeEventListener('blur', onBlur);
                                    if (!hasOpened) {
                                        index++;
                                        tryNext();
                                    }
                                }, 500);
                            }
                            tryNext();
                        }
                    </script>
                </div>
            </section>

